-T 2C
--color=always
--no-transfer-progress
-Dmaven.ext.class.path=.mvn/extensions/oculix-build-extensions.jar

# OculiX-flavored log surface — see build-extensions/.../OculixBuildBanner
# for the matching ANSI styling. Drops the default [INFO]/[WARN]/[ERROR]
# brackets, replaces with a discreet 2-char glyph so every log line stays
# scannable but stops shouting "[INFO]" at the user.
-Dorg.slf4j.simpleLogger.levelInBrackets=false
-Dorg.slf4j.simpleLogger.infoLevelString=  ::
-Dorg.slf4j.simpleLogger.warnLevelString=(!)
-Dorg.slf4j.simpleLogger.errorLevelString=(X)
-Dorg.slf4j.simpleLogger.cacheOutputStream=true
